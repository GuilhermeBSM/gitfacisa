import mysql.connector


def criar_conexao():
    try:
        return mysql.connector.connect(
            host="localhost",
            user="root",
            password="1234",
            database="ouvidoria"
        )
    except mysql.connector.Error as err:
        print(f"Erro ao conectar: {err}")
        return None


def inicializar_tabela():
    conexao = criar_conexao()
    if not conexao:
        return

    with conexao.cursor() as cursor:
        cursor.execute("""
            CREATE TABLE IF NOT EXISTS reclamacoes (
                id INT AUTO_INCREMENT PRIMARY KEY,
                texto TEXT NOT NULL
            )
        """)
        conexao.commit()

    conexao.close()



def registrar_reclamacao():
    conexao = criar_conexao()
    if not conexao:
        return

    texto = input("Digite a reclamação: ")
    sql = "INSERT INTO reclamacoes (texto) VALUES (%s)"

    with conexao.cursor() as cursor:
        cursor.execute(sql, (texto,))
        conexao.commit()
        print("Reclamação registrada com sucesso!")

    conexao.close()


def listar_reclamacoes():
    conexao = criar_conexao()
    if not conexao:
        return
 with conexao.cursor() as cursor:
        cursor.execute("SELECT * FROM reclamacoes")

        print("\nLista de Reclamações:")
        encontrou = False

        for (id, texto) in cursor:
            print(f"Código: {id} | Reclamação: {texto}")
            encontrou = True

        if not encontrou:
            print("Nenhuma reclamação registrada.")

    conexao.close()


def pesquisar_reclamacao():
    conexao = criar_conexao()
    if not conexao:
        return

    codigo = input("Digite o código: ")

    if not codigo.isdigit():
        print("Digite um número válido!")
        return

    sql = "SELECT * FROM reclamacoes WHERE id = %s"

    with conexao.cursor() as cursor:
        cursor.execute(sql, (codigo,))
        resultado = cursor.fetchone()

        if resultado:
            print(f"Reclamação encontrada: {resultado[1]}")
        else:
            print("Reclamação não encontrada.")

    conexao.close()


def atualizar_reclamacao():
    conexao = criar_conexao()
    if not conexao:
        return
codigo = input("Digite o código: ")

    if not codigo.isdigit():
        print("Digite um número válido!")
        return

    novo_texto = input("Digite a nova reclamação: ")

    sql = "UPDATE reclamacoes SET texto = %s WHERE id = %s"

    with conexao.cursor() as cursor:
        cursor.execute(sql, (novo_texto, codigo))
        conexao.commit()

        if cursor.rowcount > 0:
            print("Atualizada com sucesso!")
        else:
            print("Reclamação não encontrada.")

    conexao.close()


def remover_reclamacao():
    conexao = criar_conexao()
    if not conexao:
        return

    codigo = input("Digite o código: ")

    if not codigo.isdigit():
        print("Digite um número válido!")
        return

    sql = "DELETE FROM reclamacoes WHERE id = %s"

    with conexao.cursor() as cursor:
        cursor.execute(sql, (codigo,))
        conexao.commit()

        if cursor.rowcount > 0:
            print("Removida com sucesso!")
        else:
            print("Reclamação não encontrada.")

    conexao.close()


def total_reclamacoes():
    conexao = criar_conexao()
    if not conexao:
        return
with conexao.cursor() as cursor:
        cursor.execute("SELECT COUNT(*) FROM reclamacoes")
        total = cursor.fetchone()
        print(f"Total de reclamações: {total[0]}")

    conexao.close()


# MENU

def menu():
    inicializar_tabela()

    while True:
        print("\n=== SISTEMA DE OUVIDORIA (MYSQL) ===")
        print("1 - Listar reclamações")
        print("2 - Registrar nova reclamação")
        print("3 - Pesquisar reclamação")
        print("4 - Atualizar reclamação")
        print("5 - Remover reclamação")
        print("6 - Total de reclamações")
        print("7 - Sair")

        opcao = input("Escolha: ").strip()

        if opcao == "1":
            listar_reclamacoes()

        elif opcao == "2":
            registrar_reclamacao()

        elif opcao == "3":
            pesquisar_reclamacao()

        elif opcao == "4":
            atualizar_reclamacao()

        elif opcao == "5":
            remover_reclamacao()

        elif opcao == "6":
            total_reclamacoes()

        elif opcao == "7":
            print("Encerrando...")
            break

        else:
            print("Opção inválida!")


# EXECUÇÃO
menu()
